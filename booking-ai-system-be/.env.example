# ===== Database (Supabase PostgreSQL) =====
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_KEY=<service_role_key>
SUPABASE_ANON_KEY=<anon_key>
DATABASE_URL=postgresql://postgres:<password>@<project>.supabase.co:5432/postgres

# ===== OpenAI (tùy chọn, fallback) =====
OPENAI_API_KEY=sk-...

# ===== Groq — LLM thay thế OpenAI (tương thích OpenAI SDK) =====
GROQ_API_KEY=
GROQ_MODEL=mixtral-8x7b-32768
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ===== Auth — Supabase Auth JWT verification (asymmetric / JWKS) =====
# URL JWKS của project Supabase — verify token ECC P-256
# Ví dụ: https://<project>.supabase.co/auth/v1/keys
SUPABASE_JWKS_URL=https://<project>.supabase.co/auth/v1/keys
JWT_ALGORITHM=ES256
# Whitelist email được phép vào /api/admin/* (cách nhau bởi dấu phẩy)
ADMIN_EMAILS=["admin@example.com"]

# ===== CORS =====
CORS_ORIGINS=["http://localhost:3000"]

# ===== Booking time =====
SHOP_TIMEZONE=Asia/Ho_Chi_Minh
MINIMUM_BOOKING_ADVANCE_MINUTES=15

# ===== Test (Supabase test user — chỉ dùng khi chạy pytest) =====
SUPABASE_TEST_EMAIL=test-admin@example.com
SUPABASE_TEST_PASSWORD=test-password
